# Copy to `.env` and fill in. `.env` is gitignored. Loaded via python-dotenv.

# Hugging Face — read+write token, used to push trained adapters to the Hub.
HUGGING_FACE_HUB_TOKEN=

# Weights & Biases — API key for experiment tracking.
WANDB_API_KEY=
# Set to "disabled" to turn W&B logging off entirely (offline / CI runs).
WANDB_MODE=online

# Anthropic — used ONLY for the LLM-as-judge step (Phases 2 and 6).
ANTHROPIC_API_KEY=

# Optional: point the HF dataset/model cache at a persistent volume.
# On Colab, set this to a Google Drive path; on Modal, to the mounted volume.
# HF_HOME=
